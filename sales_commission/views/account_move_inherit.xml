<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_commission_salesman" model="ir.ui.view">
        <field name="name">account.move.form.commission.salesman</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='team_id']" position="after">
                <field
                    name="commission_salesman_id"
                    readonly="1"
                    invisible="move_type != 'out_invoice'"
                    string="Commission Salesman"
                />
            </xpath>

        </field>
    </record>
</odoo>