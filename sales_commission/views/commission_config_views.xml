<odoo>
    <!--  ── List View ──  -->
    <record id="commission_config_tree_view" model="ir.ui.view">
        <field name="name">commission.config.list</field>
        <field name="model">commission.config</field>
        <field name="arch" type="xml">
            <list string="Commission Configuration">
                <field name="company_id"/>
                <field name="expense_account_id"/>
                <field name="journal_id"/>
            </list>
        </field>
    </record>

    <!--  ── Form View ──  -->
    <record id="commission_config_form_view" model="ir.ui.view">
        <field name="name">commission.config.form</field>
        <field name="model">commission.config</field>
        <field name="arch" type="xml">
            <form string="Commission Configuration">
                <sheet>
                    <div class="alert alert-danger" role="alert" invisible="expense_account_id != False and journal_id != False">
                        Please set both Commission Expense Account and Payment Journal before processing any commission payments.
                    </div>
                    <div class="oe_title">
                        <h1>Commission Configuration</h1>
                    </div>
                    <group string="Company">
                        <field name="company_id" readonly="1"/>
                    </group>
                    <group string="Accounting">
                        <group>
                            <field name="expense_account_id"/>
                            <field name="journal_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--  ── Action ──  -->
    <record id="commission_config_action" model="ir.actions.act_window">
        <field name="name">Commission Settings</field>
        <field name="res_model">commission.config</field>
        <field name="view_mode">list,form</field>
        <field name="target">current</field>
    </record>

    <!--  ── Root Menu ──  -->
    <menuitem id="menu_commission_config" name="Commission" parent="hr.menu_human_resources_configuration" sequence="99"/>

    <!--  ── Sub Menu ──  -->
    <menuitem id="menu_commission_config_sub" name="Commission Settings" parent="menu_commission_config" action="commission_config_action" sequence="10"/>
</odoo>