<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_pli" model="ir.ui.view">
        <field name="name">res.config.settings.form.payment.link.in</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_payment_section']" position="inside">
                <setting string="Payment Link In"
                         help="Record incoming money that has no order behind it">
                    <field name="pos_payment_link_in_enabled"/>
                    <div class="mt16" invisible="not pos_payment_link_in_enabled">
                        <field name="pos_payment_link_in_journal_id"
                               options="{'no_create': True}"/>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>