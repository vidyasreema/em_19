<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_delivery_zone_form" model="ir.ui.view">
        <field name="name">delivery.zone.form</field>
        <field name="model">delivery.zone</field>
        <field name="arch" type="xml">
            <form string="Delivery Zone">
                <sheet>

                    <group>
                        <group>
                            <field name="name" placeholder="e.g., Dubai Marina Zone"/>
                            <field name="code" placeholder="e.g., DXB-MARINA"/>
                        </group>
                        <group>
                            <field name="delivery_method_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Zone Map" name="map">
                            <!-- Instructions and search box are rendered by the widget itself -->
                            <field name="polygon" widget="polygon_map_widget" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_delivery_zone_list" model="ir.ui.view">
        <field name="name">delivery.zone.list</field>
        <field name="model">delivery.zone</field>
        <field name="arch" type="xml">
            <list string="Delivery Zones">
                <field name="name"/>
                <field name="code"/>
                <field name="delivery_method_id"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_delivery_zone" model="ir.actions.act_window">
        <field name="name">Delivery Zones</field>
        <field name="res_model">delivery.zone</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_delivery_zone_root"
              name="Delivery Zones"
              parent="website_sale.menu_ecommerce_settings"
              action="action_delivery_zone"
              sequence="91"/>

</odoo>