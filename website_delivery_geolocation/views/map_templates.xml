<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Map Widget on Address Page (Google Maps) -->
    <template id="address_map_selector"
              inherit_id="website_sale.address"
              name="Google Map Address Selector">

        <xpath expr="//form[@action='/shop/address/submit']" position="before">
            <div class="o_map_address_selector mb-4">
                <div class="card shadow-sm">

                    <!-- Header -->
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fa fa-map-marker-alt me-2"></i>
                            Select Your Location on Map
                        </h5>
                    </div>

                    <!-- Body -->
                    <div class="card-body">

                        <div class="alert alert-info mb-3">
                            <i class="fa fa-info-circle me-2"></i>
                            Click on the map or drag the marker to select your address.
                            The address form will be filled automatically.
                        </div>

                        <!-- Search -->
                        <div class="row g-2 mb-3">
                            <div class="col-md-9">
                                <input type="text"
                                       id="o_map_search_input"
                                       class="form-control"
                                       placeholder="Search for your location (street, area, landmark)"/>
                            </div>
                            <div class="col-md-3">
                                <button type="button"
                                        id="o_map_search_btn"
                                        class="btn btn-primary w-100">
                                    <i class="fa fa-search me-1"></i> Search
                                </button>
                            </div>
                        </div>

                        <!-- Google Map Container -->
                        <div id="o_delivery_map"
                             style="width: 100%; height: 500px;"></div>

                        <!-- Selected Location -->
                        <div id="o_map_selected_location" class="mt-3 d-none">
                            <h6 class="mb-2">
                                <i class="fa fa-check-circle me-2"></i>
                                Selected Location
                            </h6>
                            <p id="o_map_selected_address" class="mb-1 fw-semibold"></p>
                            <small class="text-muted">
                                <i class="fa fa-map-pin me-1"></i>
                                Coordinates:
                                <span id="o_map_selected_coords"></span>
                            </small>
                        </div>

                        <!-- Action Buttons -->
                        <div class="mt-3 d-flex gap-2 flex-wrap">
                            <button type="button"
                                    id="o_map_current_location_btn"
                                    class="btn btn-outline-primary btn-sm">
                                <i class="fa fa-crosshairs me-1"></i>
                                Use My Current Location
                            </button>

                            <button type="button"
                                    id="o_map_clear_btn"
                                    class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-times me-1"></i>
                                Clear Selection
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        </xpath>
    </template>

</odoo>
