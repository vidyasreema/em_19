<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='!props.showRemainingButtons || (ui.isSmall and props.showRemainingButtons)']" position="after">
            <button t-if="!props.showRemainingButtons"
                    class="lpo-button"
                    t-att-class="buttonClass"
                    t-on-click="() => this.onClickLpo()">
                <i class="fa fa-file-text-o me-1" role="img" aria-label="LPO" title="LPO"/>
                LPO
                <span t-if="currentOrder?.lpo_number" class="badge text-bg-primary ms-1">
                    <t t-esc="currentOrder.lpo_number"/>
                    <i class="fa fa-times ms-1"
                       role="img"
                       aria-label="Clear LPO"
                       title="Clear LPO"
                       t-on-click.stop="() => this.onClickClearLpo()"/>
                </span>
            </button>
        </xpath>
    </t>
</templates>
