<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        ir.actions.report record
        ─────────────────────────
        • model           : res.partner (where the x_studio_* fields live)
        • report_type     : qweb-pdf  (renders via wkhtmltopdf)
        • report_name     : must match the abstract model _name
                            report.<module>.<template_id>
        • binding_model_id: adds "Customer Performance Analysis" under
                            the Print menu in Contacts (form + list view)
    -->
    <record id="action_customer_performance_report" model="ir.actions.report">
        <field name="name">Customer Performance Analysis</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_contact_report.customer_performance_template</field>
        <field name="report_file">custom_contact_report.customer_performance_template</field>
        <field name="print_report_name">'Customer_Performance_' + (object.name or 'Report')</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
