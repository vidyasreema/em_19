<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="paperformat_catalog" model="report.paperformat">
        <field name="name">Catalog Full Bleed A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="disable_shrinking" eval="True"/>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_catalog" model="ir.actions.report">
        <field name="name">Catalog</field>
        <field name="model">catalog.builder</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">catalog_builder.report_catalog_document</field>
        <field name="report_file">catalog_builder.report_catalog_document</field>
        <field name="paperformat_id" ref="catalog_builder.paperformat_catalog"/>
        <field name="binding_model_id" ref="model_catalog_builder"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_catalog_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">

                <!-- Pull the configuration record (logo, cover, QR, contact details) -->
                <t t-set="cfg" t-value="doc.env['catalog.config'].search([('active','=',True)], limit=1)"/>

                <div class="catalog-root">
                    <style>
                        @page { size: A4 portrait; margin: 0; }
                        * { margin:0; padding:0; box-sizing:border-box; }
                        html, body { margin:0; padding:0; width:100%; height:100%; background-color:#5c1a2b; }

                        .page { width:100%; height:297mm; position:relative;
                        overflow:hidden; page-break-after:always;
                        font-family:'Arial Narrow','Oswald',sans-serif; color:#f0e6d2;
                        -webkit-print-color-adjust:exact; print-color-adjust:exact; }
                        .page:last-child { page-break-after:auto; }

                        .sep { display:inline-block; width:4px; height:4px; border-radius:50%;
                        background-color:currentColor; vertical-align:middle;
                        margin:0 7px; opacity:.75; }

                        /* ================= COVER ================= */
                        .cover { background-color:#5c1a2b; padding:70px 58px 0; }
                        .cover-top { position:relative; height:120px; }
                        .cover-top .logo-img { width:120px; height:auto; }
                        .cover-meta { position:absolute; top:18px; right:0; text-align:right; }
                        .cover-meta .no { font-size:15px; font-weight:700; letter-spacing:3px; color:#f0e6d2; }
                        .cover-meta .dt { font-size:14px; letter-spacing:3px; color:#c2a25a; margin-top:7px; }

                        .hero { margin-top:30px; height:355px; background-color:#2c0e16;
                        border-radius:16px; overflow:hidden;
                        display:table; table-layout:fixed; width:100%; }
                        .hero-cell { display:table-cell; vertical-align:middle; text-align:center;
                        color:#6f535b; font-size:13px; letter-spacing:5px; }
                        .hero img { max-width:100%; max-height:355px; height:auto; width:auto;
                        display:inline-block; vertical-align:middle; border-radius:14px; }

                        .cover-title { font-size:74px; font-weight:700; line-height:.9;
                        letter-spacing:1px; color:#f3ead7; margin-top:50px; }
                        .cover-rule { width:92px; height:3px; background-color:#c2a25a; margin:24px 0 16px; }
                        .cover-tag  { font-size:15px; letter-spacing:6px; color:#e7dcc2; }

                        /* ================= GRID PAGE ================= */
                        .grid-page { background-color:#efe5d0; color:#5c1a2b; }
                        .grid-band { background-color:#5c1a2b; color:#f0e6d2;
                        padding:44px 58px; position:relative; }
                        .grid-head { font-size:38px; font-weight:700; letter-spacing:1px; line-height:1; }
                        .grid-sub  { font-size:13px; letter-spacing:4px; color:#c2a25a; margin-top:10px; }
                        .grid-logo-img { position:absolute; top:30px; right:54px; width:84px; height:auto; }

                        .cards { padding:30px 44px 0; font-size:0; }
                        .cards-last { padding-bottom:130px; }
                        .card  { display:inline-block; width:47%; margin:1.5%; vertical-align:top;
                        background-color:#fbf7ee; border-radius:12px; overflow:hidden; }
                        .card-img { height:160px; background-color:#2c0e16; width:100%;
                        display:table; table-layout:fixed; overflow:hidden; }
                        .card-img-cell { display:table-cell; vertical-align:middle; text-align:center;
                        color:#6f535b; font-size:12px; letter-spacing:5px; }
                        .card-img img { max-width:100%; max-height:160px; height:auto; width:auto;
                        display:inline-block; vertical-align:middle; }
                        .card-strip { background-color:#e7decb; padding:7px 14px; font-size:12px; color:#5c1a2b; }
                        .card-body { padding:14px 16px 18px; }
                        .card-name { font-size:19px; font-weight:700; color:#3d1320; line-height:1.1; }
                        .card-desc { font-size:12px; color:#94785f; letter-spacing:1px; margin-top:5px; }
                        .price-btn { display:inline-block; background-color:#5c1a2b; color:#f0e6d2;
                        font-weight:700; font-size:15px; letter-spacing:2px;
                        padding:9px 18px; border-radius:8px; margin-top:14px; }

                        .badges-band { position:absolute; bottom:0; left:0; right:0;
                        background-color:#5c1a2b; padding:24px 30px; text-align:center; }
                        .badges-row { width:100%; }
                        .badge { display:inline-block; vertical-align:middle;
                        min-width:128px; height:38px; line-height:36px;
                        border:1px solid #c2a25a; border-radius:19px;
                        margin:5px 5px; padding:0 18px; font-size:11px;
                        letter-spacing:3px; color:#f0e6d2; white-space:nowrap;
                        text-align:center; }

                        /* ================= THANKS ================= */
                        .thanks { background-color:#5c1a2b; text-align:center; padding-top:46px; }
                        .thanks .logo-img { width:132px; height:auto; margin:0 auto; }
                        .thanks-title { font-size:46px; font-weight:700; line-height:1.0;
                        letter-spacing:1px; color:#f3ead7; margin-top:30px; }
                        .thanks-rule { width:64px; height:3px; background-color:#c2a25a; margin:24px auto; }
                        .addr { font-size:17px; line-height:2.05; color:#e7dcc2; letter-spacing:.5px; }
                        .qr { width:122px; height:122px; background-color:#f0e6d2;
                        border-radius:14px; padding:10px; margin:32px auto; }
                        .qr img { width:100%; height:100%; }
                        .delivery { font-size:14px; letter-spacing:5px; color:#c2a25a; margin-top:6px; }
                        .thanks-foot { position:absolute; bottom:30px; left:0; right:0;
                        font-size:11px; letter-spacing:2px; color:#9c7782; }
                    </style>

                    <!-- ===== PAGE 1: COVER ===== -->
                    <div class="page cover">
                        <div class="cover-top">
                            <img t-if="cfg.logo" class="logo-img" t-att-src="image_data_uri(cfg.logo)"/>
                            <div class="cover-meta">
                                <div class="no">No. <span t-field="doc.name"/></div>
                                <div class="dt"><span t-field="doc.date"/></div>
                            </div>
                        </div>

                        <t t-set="hero_img" t-value="cfg.cover_image or (doc.line_ids[0].image if doc.line_ids else False)"/>
                        <div class="hero">
                            <div class="hero-cell">
                                <img t-if="hero_img" t-att-src="image_data_uri(hero_img)"/>
                                <t t-else="">PRODUCT HERO IMAGE</t>
                            </div>
                        </div>

                        <div class="cover-title">PRODUCT<br/>CATALOG</div>
                        <div class="cover-rule"></div>
                        <div class="cover-tag">PREMIUM SELECTION <span class="sep"/> 2026</div>
                    </div>

                    <!-- ===== PRODUCT GRID (paginated) ===== -->
                    <t t-set="per_page" t-value="4"/>
                    <t t-set="all_lines" t-value="doc.line_ids"/>
                    <t t-set="chunks" t-value="[all_lines[i:i + per_page] for i in range(0, len(all_lines), per_page)] or [all_lines]"/>
                    <t t-foreach="chunks" t-as="chunk">
                        <t t-set="is_last_grid" t-value="chunk_index == len(chunks) - 1"/>
                        <div class="page grid-page">
                            <div class="grid-band">
                                <div class="grid-head">PREMIUM COLLECTION</div>
                                <div class="grid-sub">SELECTED CUTS <span class="sep"/> GRASS-FED</div>
                                <img t-if="cfg.logo" class="grid-logo-img" t-att-src="image_data_uri(cfg.logo)"/>
                            </div>

                            <div t-attf-class="cards #{'cards-last' if is_last_grid else ''}">
                                <t t-foreach="chunk" t-as="line">
                                    <div class="card">
                                        <div class="card-img">
                                            <div class="card-img-cell">
                                                <img t-if="line.image" t-att-src="image_data_uri(line.image)"/>
                                                <t t-else="">IMAGE</t>
                                            </div>
                                        </div>
                                        <div class="card-strip" t-if="line.origin">
                                            <span t-esc="line.origin"/>
                                        </div>
                                        <div class="card-body">
                                            <div class="card-name"><span t-esc="line.name.split(']')[-1].strip() if (line.name and ']' in line.name) else (line.name or '')"/></div>
                                            <div class="card-desc" t-esc="line.description or ''"/>
                                            <div class="price-btn">AED <span t-esc="'%.0f' % (line.price or 0)"/></div>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <div class="badges-band" t-if="is_last_grid">
                                <div class="badges-row">
                                    <t t-if="cfg.badges">
                                        <t t-foreach="[b.strip() for b in cfg.badges.splitlines() if b.strip()]" t-as="badge">
                                            <span class="badge" t-esc="badge"/>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <span class="badge">GRASS-FED</span>
                                        <span class="badge">NO HORMONES</span>
                                        <span class="badge">NO ANTIBIOTICS</span>
                                        <span class="badge">OMEGA-3</span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- ===== PAGE 3: THANK YOU ===== -->
                    <div class="page thanks">
                        <img t-if="cfg.logo" class="logo-img" t-att-src="image_data_uri(cfg.logo)"/>
                        <div class="thanks-title">WE'D BE GLAD<br/>TO SERVE YOU</div>
                        <div class="thanks-rule"></div>
                        <div class="addr">
                            <span t-if="cfg.company_address" t-esc="cfg.company_address"/><br t-if="cfg.company_address"/>
                            <t t-if="cfg.phone">Tel <span t-esc="cfg.phone"/></t>
                            <t t-if="cfg.whatsapp"> <span class="sep"/> WhatsApp <span t-esc="cfg.whatsapp"/></t><br/>
                            <span t-if="cfg.website" t-esc="cfg.website"/>
                            <t t-if="cfg.instagram"> <span class="sep"/> <span t-esc="cfg.instagram"/></t>
                        </div>
                        <div class="qr" t-if="cfg.qr_image">
                            <img t-att-src="image_data_uri(cfg.qr_image)"/>
                        </div>
                        <div class="delivery" t-if="cfg.delivery_note" t-esc="cfg.delivery_note"/>
                        <div class="thanks-foot">
                            No. <span t-field="doc.name"/> <span class="sep"/> <span t-field="doc.date"/>
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>