<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_catalog_builder_wizard_form" model="ir.ui.view">
        <field name="name">catalog.builder.wizard.form</field>
        <field name="model">catalog.builder.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Products">
                <group>
                    <field name="category_id"/>
                </group>
                <field name="selected_product_ids" widget="many2many_checkboxes" domain="[('id', 'in', product_ids)]"/>
                <footer>
                    <button name="action_confirm" type="object" string="Next" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>