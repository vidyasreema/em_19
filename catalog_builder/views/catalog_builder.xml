<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form view -->
    <record id="view_catalog_builder_form" model="ir.ui.view">
        <field name="name">catalog.builder.form</field>
        <field name="model">catalog.builder</field>
        <field name="arch" type="xml">
            <form string="Catalog">
                <header>
                    <button name="action_preview" type="object" string="Preview"
                            class="btn-secondary" invisible="not line_ids"/>
                    <button name="action_print_save" type="object" string="Print &amp; Save"
                            class="btn-primary" invisible="not line_ids"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="template"/>
                        </group>
                        <group>
                            <field name="customer_id"/>
                            <field name="pdf_filename" invisible="1"/>
                            <field name="pdf_file" filename="pdf_filename"
                                   readonly="1" invisible="state != 'done'"/>
                        </group>
                    </group>
                    <button name="action_open_product_picker" type="object"
                            string="Select Products" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <notebook>
                        <page string="Products">
                            <field name="line_ids">
                                <!-- List: click a row to open the editor dialog -->
                                <list>
                                    <field name="image" widget="image" width="60px"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="price"/>
                                    <field name="origin"/>
                                    <field name="description"/>
                                    <field name="is_modified" widget="boolean_toggle" readonly="1"/>
                                </list>
                                <!-- Form dialog: full per-product editor incl. image -->
                                <form string="Edit Catalog Product">
                                    <sheet>
                                        <field name="image" widget="image" class="oe_avatar"/>
                                        <group>
                                            <group>
                                                <field name="product_id" readonly="1"/>
                                                <field name="name"/>
                                                <field name="price"/>
                                            </group>
                                            <group>
                                                <field name="origin"/>
                                                <field name="description"/>
                                                <field name="is_modified" readonly="1"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List view -->
    <record id="view_catalog_builder_list" model="ir.ui.view">
        <field name="name">catalog.builder.list</field>
        <field name="model">catalog.builder</field>
        <field name="arch" type="xml">
            <list string="Catalogs">
                <field name="name"/>
                <field name="date"/>
                <field name="customer_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_catalog_builder" model="ir.actions.act_window">
        <field name="name">Catalogs</field>
        <field name="res_model">catalog.builder</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="module_category_catalog_builder" model="ir.module.category">
        <field name="name">Catalog Builder</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_catalog_user" model="res.groups">
        <field name="name">Catalog Builder User</field>
        <field name="comment">Can view and use the Catalog Builder menus.</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_catalog_builder_root" name="Catalog Builder" sequence="50"
              groups="catalog_builder.group_catalog_user"/>
    <menuitem id="menu_catalog_builder_main" name="Catalogs"
              parent="menu_catalog_builder_root"
              action="action_catalog_builder" sequence="10"
              groups="catalog_builder.group_catalog_user"/>
</odoo>