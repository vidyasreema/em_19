<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_category_form_catalog" model="ir.ui.view">
        <field name="name">product.category.form.catalog</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="catalog_image" widget="image"
                       class="oe_avatar"/>
            </field>
        </field>
    </record>
</odoo>