<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_catalog_builder_form" model="ir.ui.view">
        <field name="name">catalog.builder.form</field>
        <field name="model">catalog.builder</field>
        <field name="arch" type="xml">
            <form string="Catalog">
                <header>
                    <button name="action_preview" type="object"
                            string="Preview" class="btn-secondary"
                            invisible="not id"/>
                    <button name="action_print_catalog" type="object"
                            string="Print Catalog" class="btn-primary"
                            invisible="not id"/>
                    <button name="action_reset_draft" type="object"
                            string="Reset to Draft"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="config_id"/>
                        </group>
                        <group>
                            <field name="line_count"/>
                        </group>
                    </group>

                    <group>
                        <field name="pdf_file" filename="pdf_filename"
                               readonly="1" invisible="not pdf_file"/>
                    </group>

                    <!-- ===== the main selection ===== -->
                    <group string="Load by Category + Country (empty = all)">
                        <group>
                            <field name="category_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="origin_value_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <div style="margin-bottom:8px;">
                        <button name="action_load_products" type="object"
                                string="Load Products" class="btn-primary"
                                invisible="not id"/>
                        <span class="text-muted" invisible="id">
                            Save the catalog first to enable loading.
                        </span>
                    </div>

                    <notebook>
                        <page string="Products">
                            <field name="line_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="image" widget="image"
                                           options="{'size': [48, 48]}"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="category_id" optional="show"/>
                                    <field name="origin_text" optional="show"/>
                                    <field name="origin" optional="hide"/>
                                    <field name="price"/>
                                </list>
                                <form string="Catalog Line">
                                    <sheet>
                                        <div class="oe_title">
                                            <label for="name"/>
                                            <h2><field name="name"
                                                       placeholder="Name shown in catalog"/></h2>
                                        </div>
                                        <group>
                                            <group string="Shown in Catalog">
                                                <field name="image" widget="image"/>
                                                <field name="price"/>
                                                <field name="description"
                                                       placeholder="Short description"/>
                                                <field name="origin"
                                                       placeholder="Override origin (optional)"/>
                                            </group>
                                            <group string="Source (read-only)">
                                                <field name="product_id" readonly="1"/>
                                                <field name="category_id" readonly="1"/>
                                                <field name="origin_text" readonly="1"/>
                                            </group>
                                        </group>
                                        <div class="text-muted">
                                            Editing name, image, price, or description here only
                                            changes how this product appears in the catalog.
                                            The original product is not affected.
                                        </div>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_catalog_builder_list" model="ir.ui.view">
        <field name="name">catalog.builder.list</field>
        <field name="model">catalog.builder</field>
        <field name="arch" type="xml">
            <list string="Catalogs">
                <field name="name"/>
                <field name="date"/>
                <field name="line_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'generated'"
                       decoration-muted="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="action_catalog_builder" model="ir.actions.act_window">
        <field name="name">Catalogs</field>
        <field name="res_model">catalog.builder</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_catalog_catalogs" name="Catalogs"
              parent="menu_catalog_root" action="action_catalog_builder"
              sequence="10"/>

</odoo>