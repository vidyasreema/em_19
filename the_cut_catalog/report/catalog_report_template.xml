<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_catalog_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="cfg" t-value="doc.config_id or doc.env['catalog.config'].search([('active','=',True)], limit=1)"/>

                <div class="catalog-root">
                    <style>
                        @page { size: A4 portrait; margin: 0; }
                        * { margin:0; padding:0; box-sizing:border-box; }
                        html, body { margin:0; padding:0; width:100%; height:100%; background-color:#5c1a2b; }
                        .page { width:100%; height:297mm; position:relative; overflow:hidden;
                        page-break-after:always; font-family:'Arial Narrow','Oswald',sans-serif;
                        color:#f0e6d2; -webkit-print-color-adjust:exact; print-color-adjust:exact; }
                        .page:last-child { page-break-after:auto; }
                        .sep { display:inline-block; width:4px; height:4px; border-radius:50%;
                        background-color:currentColor; vertical-align:middle; margin:0 7px; opacity:.75; }

                        /* COVER */
                        .cover { background-color:#5c1a2b; padding:70px 58px 0; }
                        .cover-top { position:relative; height:120px; }
                        .cover-top .logo-img { width:120px; height:auto; }
                        .cover-meta { position:absolute; top:18px; right:0; text-align:right; }
                        .cover-meta .no { font-size:15px; font-weight:700; letter-spacing:3px; color:#f0e6d2; }
                        .cover-meta .dt { font-size:14px; letter-spacing:3px; color:#c2a25a; margin-top:7px; }
                        .hero { margin-top:30px; height:355px; background-color:#2c0e16; border-radius:16px;
                        overflow:hidden; display:table; table-layout:fixed; width:100%; }
                        .hero-cell { display:table-cell; vertical-align:middle; text-align:center;
                        color:#6f535b; font-size:13px; letter-spacing:5px; }
                        .hero img { max-width:100%; max-height:355px; height:auto; width:auto;
                        display:inline-block; vertical-align:middle; border-radius:14px; }
                        .cover-title { font-size:74px; font-weight:700; line-height:.9; letter-spacing:1px;
                        color:#f3ead7; margin-top:50px; }
                        .cover-rule { width:92px; height:3px; background-color:#c2a25a; margin:24px 0 16px; }
                        .cover-tag { font-size:15px; letter-spacing:6px; color:#e7dcc2; }

                        /* GRID */
                        .grid-page { background-color:#efe5d0; color:#5c1a2b; }
                        .grid-band { background-color:#5c1a2b; color:#f0e6d2; padding:18px 58px; position:relative; }
                        .grid-head { font-size:28px; font-weight:700; letter-spacing:1px; line-height:1; }
                        .grid-logo-img { position:absolute; top:16px; right:54px; width:56px; height:auto; }
                        /* Inline category marker (replaces the old full-page divider).
                        Shown wherever the animal/category changes within the packed
                        card flow, so a page can contain the tail of one category's
                        products and the start of the next one's, with no forced
                        page break and no wasted blank space at the boundary. */
                        .category-band { margin:14px 40px 0; background-color:#2c0e16; color:#f3ead7;
                        border-radius:12px; padding:10px 20px; font-size:20px; font-weight:700;
                        letter-spacing:2px; }
                        .origin-bar { margin:10px 40px 0; background-color:#7a1f33; border-radius:12px;
                        padding:8px 20px; color:#f0e6d2; }
                        .origin-bar .flag { width:26px; height:18px; vertical-align:middle; margin-right:12px;
                        border-radius:4px; border:.5px solid #d2c8b2; }
                        .origin-bar .oname { font-size:17px; font-weight:700; vertical-align:middle; }
                        .origin-bar .ocount { display:inline-block; vertical-align:middle; background-color:#efe5d0;
                        color:#5c1a2b; font-size:12px; font-weight:700; border-radius:12px; padding:2px 11px; margin-left:14px; }
                        .cards { padding:10px 40px 0; font-size:0; }
                        /* 3 cards per row x 4 rows = 12 per page. */
                        .card { display:inline-block; width:31%; height:200px; margin:0.9% 1.15%; vertical-align:top;
                        background-color:#fbf7ee; border-radius:12px; overflow:hidden; padding-bottom:4px; }
                        .card-img { height:100px; background-color:#2c0e16; width:100%; display:table;
                        table-layout:fixed; overflow:hidden; }
                        .card-img-cell { display:table-cell; vertical-align:middle; text-align:center;
                        color:#6f535b; font-size:10px; letter-spacing:3px; }
                        .card-img img { max-width:100%; max-height:100px; height:auto; width:auto;
                        display:inline-block; vertical-align:middle; }
                        .card-origin { background-color:#efe8d8; padding:5px 12px; font-size:11px; color:#2e2a26;
                        border-bottom:1px solid #e0d8c4; }
                        .card-origin .flag { width:20px; height:14px; vertical-align:middle; margin-right:8px;
                        border-radius:4px; border:.5px solid #d2c8b2; }
                        /* Grey placeholder box shown instead of a flag when the origin
                        has no matching flag image (e.g. "Unspecified origin"). */
                        .card-origin .flag-placeholder { display:inline-block; width:20px; height:14px;
                        vertical-align:middle; margin-right:8px; border-radius:4px;
                        background-color:#b9ab97; border:.5px solid #d2c8b2; }
                        .card-origin span { vertical-align:middle; }
                        .card-body { padding:8px 12px 6px; }
                        /* Name kept at regular (non-bold) weight per request. */
                        .card-name { font-size:13px; font-weight:400; color:#3d1320; line-height:1.15;
                        display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;
                        overflow:hidden; text-overflow:ellipsis; max-height:2.1em; }
                        .card-desc { font-size:11px; color:#94785f; letter-spacing:.3px; margin-top:3px;
                        display:-webkit-box; -webkit-line-clamp:1; -webkit-box-orient:vertical;
                        overflow:hidden; text-overflow:ellipsis; }
                        overflow:hidden; text-overflow:ellipsis; }
                        /* price-btn style removed - price is no longer shown on cards. */

                        /* THANKS */
                        /* FIX: centering made explicit on every element below (instead
                        of relying on inherited text-align from .thanks) since the
                        inherited version was rendering left-aligned in the PDF. */
                        .thanks { background-color:#5c1a2b; text-align:center; padding-top:60px; }
                        .thanks .logo-img { display:block; width:132px; height:auto; margin:0 auto; }
                        .thanks-title { display:block; width:100%; text-align:center; font-size:46px; font-weight:700;
                        line-height:1.0; letter-spacing:1px; color:#f3ead7; margin-top:30px; }
                        .thanks-rule { display:block; width:64px; height:3px; background-color:#c2a25a; margin:24px auto; }
                        .addr { display:block; width:100%; text-align:center; font-size:17px; line-height:2.05;
                        color:#e7dcc2; letter-spacing:.5px; }
                        .qr { display:block; width:122px; height:122px; background-color:#f0e6d2; border-radius:14px;
                        padding:10px; margin:32px auto; }
                        .qr img { width:100%; height:100%; }
                        .delivery { display:block; width:100%; text-align:center; font-size:14px; letter-spacing:5px;
                        color:#c2a25a; margin-top:6px; }
                        .thanks-foot { position:absolute; bottom:30px; left:0; right:0; text-align:center;
                        font-size:11px; letter-spacing:2px; color:#9c7782; }
                    </style>

                    <!-- ===== COVER ===== -->
                    <div class="page cover">
                        <div class="cover-top">
                            <img t-if="cfg and cfg.logo" class="logo-img" t-att-src="image_data_uri(cfg.logo)"/>
                            <div class="cover-meta">
                                <div class="no">No. <span t-field="doc.name"/></div>
                                <div class="dt"><span t-field="doc.date"/></div>
                            </div>
                        </div>
                        <t t-set="hero_img" t-value="(cfg.cover_image if cfg else False) or (doc.line_ids[0].image if doc.line_ids else False)"/>
                        <div class="hero">
                            <div class="hero-cell">
                                <img t-if="hero_img" t-att-src="image_data_uri(hero_img)"/>
                                <t t-else="">PRODUCT HERO IMAGE</t>
                            </div>
                        </div>
                        <div class="cover-title">
                            <t t-set="ctitle" t-value="(cfg.cover_title if cfg else False) or 'PRODUCT CATALOG'"/>
                            <t t-foreach="ctitle.splitlines() or [ctitle]" t-as="cl">
                                <span t-esc="cl"/><br t-if="not cl_last"/>
                            </t>
                        </div>
                        <div class="cover-rule"></div>
                        <div class="cover-tag" t-esc="((cfg.cover_tagline if cfg else False) or 'PREMIUM SELECTION').replace('\u00e2\u20ac\u00a2', '-').replace(chr(8226), '-')"/>
                    </div>

                    <!-- ===== PRODUCT GRID (all categories flow together) =====
                         Category, origin, and card blocks are packed using a
                         row-budget model (see _pack_blocks_into_pages in the
                         model) so a page can hold the tail of one animal's
                         products and the start of the next animal's, instead
                         of always starting a fresh page per category. -->
                    <t t-set="report_pages" t-value="doc.get_report_pages()"/>
                    <t t-foreach="report_pages" t-as="page">
                        <div class="page grid-page">
                            <div class="grid-band">
                                <div class="grid-head">CATALOG</div>
                                <img t-if="cfg and cfg.logo" class="grid-logo-img" t-att-src="image_data_uri(cfg.logo)"/>
                            </div>
                            <t t-foreach="page" t-as="block">
                                <div t-if="block['type'] == 'category'" class="category-band">
                                    <span t-esc="block['name']"/>
                                </div>
                                <div t-if="block['type'] == 'header'" class="origin-bar">
                                    <img t-if="block['flag_image']" class="flag" t-att-src="'data:image/png;base64,%s' % (block['flag_image'].decode() if block['flag_image'] else '')"/>
                                    <span class="oname" t-esc="block['name']"/>
                                    <span class="ocount" t-esc="block['count']"/>
                                </div>
                                <div t-if="block['type'] == 'cards'" class="cards">
                                    <t t-foreach="block['lines']" t-as="line">
                                        <div class="card">
                                            <div class="card-img">
                                                <div class="card-img-cell">
                                                    <img t-if="line.image" t-att-src="image_data_uri(line.image)"/>
                                                    <t t-else="">IMAGE</t>
                                                </div>
                                            </div>
                                            <div class="card-origin" t-if="line.flag_image or line.origin_text">
                                                <img t-if="line.flag_image" class="flag" t-att-src="'data:image/png;base64,%s' % (line.flag_image.decode() if line.flag_image else '')"/>
                                                <span t-if="line.origin_text" t-esc="line.origin_text"/>
                                            </div>
                                            <div class="card-body">
                                                <div class="card-name">
                                                    <span t-esc="line.name.split(']')[-1].strip() if (line.name and ']' in line.name) else (line.name or '')"/>
                                                </div>
                                                <div class="card-desc" t-esc="line.description or ''"/>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </t>

                    <!-- ===== THANK YOU ===== -->
                    <div class="page thanks">
                        <img t-if="cfg and cfg.logo" class="logo-img" t-att-src="image_data_uri(cfg.logo)"/>
                        <div class="thanks-title">
                            <t t-set="ttitle" t-value="(cfg.thanks_title if cfg else False) or &quot;WE'D BE GLAD TO SERVE YOU&quot;"/>
                            <t t-foreach="ttitle.splitlines() or [ttitle]" t-as="tl">
                                <span t-esc="tl"/><br t-if="not tl_last"/>
                            </t>
                        </div>
                        <div class="thanks-rule"></div>
                        <div class="addr" t-if="cfg">
                            <span t-if="cfg.company_address" t-esc="cfg.company_address"/><br t-if="cfg.company_address"/>
                            <t t-if="cfg.phone">Tel <span t-esc="cfg.phone"/></t>
                            <t t-if="cfg.whatsapp"> <span class="sep"/> WhatsApp <span t-esc="cfg.whatsapp"/></t><br/>
                            <span t-if="cfg.website" t-esc="cfg.website"/>
                            <t t-if="cfg.instagram"> <span class="sep"/> <span t-esc="cfg.instagram"/></t>
                        </div>
                        <div class="qr" t-if="cfg and cfg.qr_image">
                            <img t-att-src="image_data_uri(cfg.qr_image)"/>
                        </div>
                        <div class="delivery" t-if="cfg and cfg.delivery_note" t-esc="cfg.delivery_note.replace('\u00e2\u20ac\u00a2', '-').replace(chr(8226), '-')"/>
                        <div class="thanks-foot">
                            No. <span t-field="doc.name"/> - <span t-field="doc.date"/>
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>