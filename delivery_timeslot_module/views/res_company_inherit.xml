                            <field name="shop_opening_time" widget="float_time"/>
                            <field name="shop_closing_time" widget="float_time"/>
                        </group>
                        <group string="Operating Days">
                            <field name="shop_monday"/>
                            <field name="shop_tuesday"/>
                            <field name="shop_wednesday"/>
                            <field name="shop_thursday"/>
                            <field name="shop_friday"/>
                            <field name="shop_saturday"/>
                            <field name="shop_sunday"/>
                        </group>
                    </group>

                    <separator string="Off-Hours Behaviour"/>

                    <group>
                        <group string="After-Close Grace Period">
                            <field name="shop_scenario2_grace_hours"
                                   string="Grace Period (hours)"
                                   help="Orders placed within this many hours after closing trigger the 'Tomorrow delivery' message (Scenario 2). Orders after this window trigger the 'Today by opening time' message (Scenario 3)."/>
