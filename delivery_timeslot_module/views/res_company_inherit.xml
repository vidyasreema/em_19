<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_company_form_inherit_shop_timing" model="ir.ui.view">
        <field name="name">res.company.form.inherit.shop.timing</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Shop Timing" name="shop_timing">

